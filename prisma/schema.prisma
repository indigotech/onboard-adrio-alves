generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        Int       @id(map: "user_pk") @default(autoincrement())
  name      String    @db.VarChar
  email     String    @db.VarChar
  password  String?   @db.VarChar
  birthdate DateTime? @db.Timestamp(6)
}
